<header
  class="fixed top-0 left-0 w-full z-50 flex justify-between items-center px-6 py-4 
         bg-white dark:bg-black/30 shadow-md backdrop-blur-md">
  
  <h1 class="text-lg font-bold">DEVURN</h1>

  
  <nav class="hidden md:flex gap-8">
    <a href="#top" class="hover:text-purple-400">Inicio</a>
    <a href="#experiencia" class="hover:text-purple-400">Experiencia</a>
    <a href="#proyectos" class="hover:text-purple-400">Proyectos</a>
    <a href="#sobre-mi" class="hover:text-purple-400">Sobre Mí</a>
    <a href="#contacto" class="hover:text-purple-400">Contacto</a>
  </nav>

  
  <button id="menu-btn" 
    class="md:hidden flex flex-col gap-1.5 focus:outline-none">
    <span class="w-6 h-0.5 bg-white"></span>
    <span class="w-6 h-0.5 bg-white"></span>
    <span class="w-6 h-0.5 bg-white"></span>
  </button>

  
  <nav id="menu" 
    class="hidden absolute top-full right-4 mt-2 w-48 rounded-xl bg-black/70 
           backdrop-blur-lg shadow-lg flex-col items-start py-4 px-6 space-y-3 animate-fade">
    <a href="#top" class="block text-white hover:text-purple-400">Inicio</a>
    <a href="#experiencia" class="block text-white hover:text-purple-400">Experiencia</a>
    <a href="#proyectos" class="block text-white hover:text-purple-400">Proyectos</a>
    <a href="#sobre-mi" class="block text-white hover:text-purple-400">Sobre Mí</a>
    <a href="#contacto" class="block text-white hover:text-purple-400">Contacto</a>
  </nav>
</header>

<script>
  const menuBtn = document.getElementById("menu-btn");
  const menu = document.getElementById("menu");
  const menuLinks = menu.querySelectorAll("a");

  
  menuBtn.addEventListener("click", (e) => {
    e.stopPropagation(); 
    menu.classList.toggle("hidden");
  });

  
  document.addEventListener("click", (e) => {
    if (!menu.contains(e.target) && !menuBtn.contains(e.target)) {
      menu.classList.add("hidden");
    }
  });

  menuLinks.forEach(link => {
    link.addEventListener("click", () => {
      menu.classList.add("hidden");
    });
  });
</script>

<style>
  @keyframes fade {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade { animation: fade 0.25s ease-in-out; }
</style>
