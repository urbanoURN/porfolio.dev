---
import Linkedin from '../components/icons/Linkedin.astro';
import Github from '../components/icons/Github.astro';
import Mail from '../components/icons/Mail.astro';
import Socialrd from '../components/Socialrd.astro';
---

<nav class="flex gap-4 nt-10 mt-8 flex-wrap">
    <Socialrd href="https://www.linkedin.com/in/edinsondevurn/">
        <Linkedin class="size-4 md:size-6" /> LinkedIn
    </Socialrd>

    <Socialrd href="https://github.com/urbanoURN">
        <Github class="size-4 md:size-6" /> GitHub
    </Socialrd>

    <!-- Gmail -->
    <Socialrd 
        href="https://mail.google.com/mail/?view=cm&fs=1&to=edinsondevurn@gmail.com&su=Consulta&body=Hola+Edinson,+me+gustaría+hablar+contigo."
        target="_blank"
        rel="noopener noreferrer"
        >
        <Mail class="size-4 d:size-6" /> Gmail
    </Socialrd>

    <!-- Outlook -->
    <Socialrd 
        href="https://outlook.office.com/mail/deeplink/compose?to=edinsondevurn@gmail.com&subject=Consulta&body=Hola+Edinson,+me+gustaría+hablar+contigo."
        target="_blank"
        rel="noopener noreferrer"
        >
        <Mail class="size-4 d:size-6" /> Outlook
    </Socialrd>

    <!-- Mailto -->
    <Socialrd 
        href="mailto:edinsondevurn@gmail.com?subject=Consulta&body=Hola%20Edinson,%20me%20gustaría%20contactarte.">
        <Mail class="size-4 d:size-6" /> edinsondevurn@gmail.com
    </Socialrd>



</nav>	